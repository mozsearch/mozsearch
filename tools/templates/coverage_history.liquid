<div id="coverage-history" class="hidden">
  <ol class="coverage-history-list">
    {%- for coverage in coverage_history -%}
      {%- capture file_url -%}/{{ tree }}/rev/{{ coverage.rev }}/{{ path }}{%- endcapture -%}
      {%- assign human_date = coverage.date | date: "%F" %}
      <li class="coverage-history-item" data-rev="{{ coverage.rev }}" data-percentage="{{ coverage.coveragePercent }}">
        <a href="{{ file_url }}">
          <time class="coverage-history-date" datetime="{{ coverage.date }}">{{ human_date }}</time>:
          <span class="coverage-history-percentage">{{ coverage.coveragePercent | round }} %</span>
        </a>
      </li>
    {%- endfor %}
  </ol>
</div>
<dialog id="coverage-graph" closedby="any"></dialog>
