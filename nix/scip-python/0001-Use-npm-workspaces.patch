From fdd536a1ec3065da604ac6bccf457991fa04b7f9 Mon Sep 17 00:00:00 2001
From: Nicolas Guichard <nicolas.guichard@kdab.com>
Date: Sun, 7 Jul 2024 16:19:43 +0200
Subject: [PATCH 1/3] Use npm workspaces

This is recommended by lerna.

From https://lerna.js.org/docs/getting-started:
> Lerna is not responsible for installing and linking your dependencies
> in your repo, your package manager is much better suited to that
> task.
> Instead, we strongly recommend configuring your package manager of
> choice to use its workspaces feature.
---
 lerna.json   | 1 +
 package.json | 3 +++
 2 files changed, 4 insertions(+)

diff --git a/lerna.json b/lerna.json
index 2692e2ddb..14b5b65e1 100644
--- a/lerna.json
+++ b/lerna.json
@@ -3,6 +3,7 @@
         "packages/*"
     ],
     "version": "1.1.301",
+    "useWorkspaces": true,
     "command": {
         "version": {
             "push": false,
diff --git a/package.json b/package.json
index e4b4890ce..f7c4476ef 100644
--- a/package.json
+++ b/package.json
@@ -1,6 +1,9 @@
 {
     "name": "pyright-root",
     "private": true,
+    "workspaces": [
+        "packages/*"
+    ],
     "scripts": {
         "postinstall": "npm run bootstrap",
         "bootstrap": "node ./build/skipBootstrap.js || lerna bootstrap",
-- 
2.54.0

